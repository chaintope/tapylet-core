{
  "name": "@tapylet/core",
  "version": "0.0.4",
  "description": "Platform-agnostic core for Tapylet — Tapyrus wallet logic (HD wallet, transactions, token issuance, storage interfaces)",
  "author": "azuchi@chaintope.com",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wallet": {
      "types": "./dist/wallet/index.d.ts",
      "default": "./dist/wallet/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^2.3.0",
    "bip39": "^3.1.0",
    "tapyrusjs-lib": "^0.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.11.5",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "prettier": "3.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "5.3.3"
  },
  "pnpm": {
    "overrides": {
      "get-intrinsic": "1.2.4"
    }
  }
}
